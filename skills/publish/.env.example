# YouTube Data API v3 (direct upload — no Buffer, no media host)
# Create a Google Cloud project, enable "YouTube Data API v3", create an OAuth
# client of type "Desktop app", then run youtube_auth.py once to fill the token.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# LLM provider for captions/titles
CAPTION_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
